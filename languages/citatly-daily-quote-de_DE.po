msgstr "Fehler beim Export:"

#: citatly-daily-quote.php
msgid "No file selected."
msgstr "Keine Datei ausgewählt."

#: citatly-daily-quote.php
msgid "File upload error."
msgstr "Fehler beim Datei-Upload."

#: citatly-daily-quote.php
msgid "Invalid file type – please upload a JSON file."
msgstr "Ungültiger Dateityp – bitte eine JSON-Datei hochladen."

#: citatly-daily-quote.php
msgid "The file is too large (max. 2 MB)."
msgstr "Die Datei ist zu groß (max. 2 MB)."

#: citatly-daily-quote.php
msgid "The JSON file could not be read or has an invalid format."
msgstr "Die JSON-Datei konnte nicht gelesen werden oder hat ein ungültiges Format."

#: citatly-daily-quote.php
msgid "The JSON file contains no entries."
msgstr "Die JSON-Datei enthält keine Einträge."

#: citatly-daily-quote.php
msgid "Unknown error."
msgstr "Unbekannter Fehler."

#: citatly-daily-quote.php
msgid "%d quote imported"
msgid_plural "%d quotes imported"
msgstr[0] "%d Zitat importiert"
msgstr[1] "%d Zitate importiert"

