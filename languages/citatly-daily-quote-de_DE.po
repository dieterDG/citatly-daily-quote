msgstr "Export"

#: citatly-daily-quote.php
msgid "Download all published quotes as a JSON file (fields: text, author, extra)."
msgstr "Alle veröffentlichten Zitate als JSON-Datei herunterladen (Felder: text, author, extra)."

#: citatly-daily-quote.php
msgid "Export JSON"
msgstr "JSON exportieren"

#: citatly-daily-quote.php
msgid "Import"
msgstr "Import"

#: citatly-daily-quote.php
msgid "Upload a JSON file (array of objects with fields text, author, extra). Existing quotes (same text) will be skipped."
msgstr "JSON-Datei hochladen (Array mit Objekten der Felder text, author, extra). Bereits vorhandene Zitate (gleicher Text) werden übersprungen."

#: citatly-daily-quote.php
msgid "Import JSON"
msgstr "JSON importieren"

#: citatly-daily-quote.php
