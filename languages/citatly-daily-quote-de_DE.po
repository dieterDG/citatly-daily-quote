msgid "%d already exists (skipped)"
msgid_plural "%d already exist (skipped)"
msgstr[0] "%d bereits vorhanden (übersprungen)"
msgstr[1] "%d bereits vorhanden (übersprungen)"

#: citatly-daily-quote.php
msgid "Help"
msgstr "Anleitung"

#: citatly-daily-quote.php
msgid "Citatly – Help"
msgstr "Citatly – Anleitung"

#: citatly-daily-quote.php
msgid "Quick Start"
msgstr "Schnellstart"

#: citatly-daily-quote.php
msgid "Activate the plugin."
msgstr "Das Plugin aktivieren."

#: citatly-daily-quote.php
msgid "Go to Quotes → Add New and create your first quote."
msgstr "Unter Zitate → Neu hinzufügen das erste Zitat anlegen."

#: citatly-daily-quote.php
msgid "Add the shortcode [citatly] to any page or post."
msgstr "Den Shortcode [citatly] in eine Seite oder einen Beitrag einfügen."

#: citatly-daily-quote.php
msgid "The quote of the day changes automatically at midnight."
msgstr "Das Zitat des Tages wechselt automatisch um Mitternacht."

#: citatly-daily-quote.php
msgid "Shortcode"
msgstr "Shortcode"

#: citatly-daily-quote.php
msgid "Basic usage:"
msgstr "Grundlegende Verwendung:"

#: citatly-daily-quote.php
msgid "With a custom CSS class:"
msgstr "Mit einer eigenen CSS-Klasse:"

#: citatly-daily-quote.php
msgid "Generated HTML structure:"
msgstr "Erzeugte HTML-Struktur:"

#: citatly-daily-quote.php
msgid "Gutenberg Block"
msgstr "Gutenberg-Block"

#: citatly-daily-quote.php
msgid "The Citatly block is available in the block editor. It requires the compiled /build directory inside the plugin folder."
msgstr "Der Citatly-Block ist im Block-Editor verfügbar. Er benötigt das kompilierte /build-Verzeichnis im Plugin-Ordner."

#: citatly-daily-quote.php
msgid "The block supports the native WordPress \"Additional CSS class(es)\" field (className). The class is passed directly to the shortcode output."
msgstr "Der Block unterstützt das native WordPress-Feld \"Zusätzliche CSS-Klasse(n)\" (className). Die Klasse wird direkt an die Shortcode-Ausgabe weitergegeben."

#: citatly-daily-quote.php
msgid "CSS Customization"
msgstr "CSS-Anpassung"

#: citatly-daily-quote.php
msgid "The following CSS classes are available for styling:"
msgstr "Folgende CSS-Klassen stehen zur Gestaltung zur Verfügung:"

#: citatly-daily-quote.php
msgid "outer container"
msgstr "äußerer Container"

#: citatly-daily-quote.php
msgid "quote text"
msgstr "Zitat-Text"

#: citatly-daily-quote.php
msgid "author and source wrapper"
msgstr "Wrapper für Autor und Quelle"

#: citatly-daily-quote.php
msgid "author name"
msgstr "Autorenname"

#: citatly-daily-quote.php
msgid "source / additional info"
msgstr "Quelle / Zusatz"

#: citatly-daily-quote.php
msgid "Example:"
msgstr "Beispiel:"

#: citatly-daily-quote.php
msgid "REST Endpoint"
msgstr "REST-Endpunkt"

#: citatly-daily-quote.php
msgid "URL:"
msgstr "URL:"

#: citatly-daily-quote.php
msgid "Method: GET – no authentication required."
msgstr "Methode: GET – keine Authentifizierung erforderlich."

#: citatly-daily-quote.php
msgid "Response format:"
msgstr "Antwortformat:"

#: citatly-daily-quote.php
msgid "The response includes Cache-Control headers. The quote changes at midnight (site timezone)."
msgstr "Die Antwort enthält Cache-Control-Header. Das Zitat wechselt um Mitternacht (Website-Zeitzone)."

#: citatly-daily-quote.php
msgid "Go to Quotes → Import / Export."
msgstr "Unter Zitate → Import / Export öffnen."

#: citatly-daily-quote.php
msgid "Format: JSON array of objects with the fields text (required), author and extra (both optional)."
msgstr "Format: JSON-Array mit Objekten der Felder text (Pflichtfeld), author und extra (beide optional)."

#: citatly-daily-quote.php
msgid "Quotes with identical text are skipped (duplicate check)."
msgstr "Zitate mit identischem Text werden übersprungen (Duplikat-Prüfung)."

#: citatly-daily-quote.php
msgid "Maximum file size: 2 MB."
msgstr "Maximale Dateigröße: 2 MB."

#: citatly-daily-quote.php
msgid "Managing Quotes"
msgstr "Zitate verwalten"

#: citatly-daily-quote.php
msgid "Quotes are stored as plain text only – no HTML, no links."
msgstr "Zitate werden ausschließlich als PlainText gespeichert – kein HTML, keine Links."

#: citatly-daily-quote.php
msgid "Line breaks in the text field are preserved in the frontend output (white-space: pre-line)."
msgstr "Zeilenumbrüche im Textfeld bleiben in der Frontend-Ausgabe erhalten (white-space: pre-line)."

#: citatly-daily-quote.php
msgid "If no title is set, one is generated automatically from the first 80 characters of the quote text."
msgstr "Ist kein Titel gesetzt, wird er automatisch aus den ersten 80 Zeichen des Zitat-Texts generiert."

#: citatly-daily-quote.php
msgid "Optional. If left empty, the title is generated automatically from the first 80 characters of the quote text."
msgstr "Optional. Wird kein Titel eingetragen, wird er automatisch aus den ersten 80 Zeichen des Zitatextes generiert."

#: src/edit.js
msgid "Quote of the Day will be displayed here"
msgstr "Zitat des Tages wird hier angezeigt"

#: src/edit.js
msgid "— Author"
msgstr "— Autor"

#: src/block.json
msgid "Daily Quote"
msgstr "Tägliches Zitat"

#: src/block.json
msgid "Displays the daily quote dynamically via REST API."
msgstr "Zeigt das tägliche Zitat dynamisch per REST-API an."

#: citatly-daily-quote.php
msgid "The most up-to-date documentation is available at <a href=\"%1$s\" target=\"_blank\" rel=\"noopener noreferrer\">%2$s</a>."
msgstr "Die aktuellste Dokumentation ist verfügbar unter <a href=\"%1$s\" target=\"_blank\" rel=\"noopener noreferrer\">citatly.com/de/docs</a>."

#. translators: %s: URL to the CSS styling documentation page
#: citatly-daily-quote.php
msgid "Interactive examples are available at <a href=\"%s\" target=\"_blank\" rel=\"noopener noreferrer\">citatly.com/docs/css-styling</a>."
msgstr "Interaktive Beispiele sind verfügbar unter <a href=\"%s\" target=\"_blank\" rel=\"noopener noreferrer\">citatly.com/de/docs/css-anpassung</a>."

#: citatly-daily-quote.php
msgid "dash before author (default: \"— \")"
msgstr "Strich vor dem Autor (Standard: \"— \")"

#: citatly-daily-quote.php
msgid "dot between author and source (default: \" · \")"
msgstr "Punkt zwischen Autor und Quelle (Standard: \" · \")"

#: citatly-daily-quote.php
msgid "☕ Support the Project"
msgstr "☕ Unterstütze das Projekt"

#: citatly-daily-quote.php
msgid "Citatly is free. If it helps you, I'd appreciate a small donation!"
msgstr "Citatly ist kostenlos. Wenn dir das Plugin hilft, freue ich mich über eine kleine Spende!"

#: citatly-daily-quote.php
msgid "☕ Ko-fi Donation"
msgstr "☕ Ko-fi Spende"
